rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Fields: uid, phone, balance, totalIncome, todayIncome, referralCode, referredBy, role, lastCheckIn, createdAt
    //
    // Collection: plans
    // Fields: id, name, price, dailyIncome, validityDays, imageUrl
    //
    // Collection: investments
    // Fields: id, userId, planId, planName, dailyIncome, purchaseDate, expiryDate, lastIncomeClaimed, status
    //
    // Collection: transactions
    // Fields: userId, amount, type, status, paymentMethod, utr, bankDetails, createdAt
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "mrkhatab112@gmail.com" ||
        request.auth.token.email == "mohdkhatab@outlook.com" ||
        request.auth.token.email == "admin@growvix.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isValidUser(data) {
      return data.uid is string && data.phone is string &&
             (data.balance is number || !('balance' in data)) &&
             (data.depositBalance is number || !('depositBalance' in data)) &&
             (data.withdrawableBalance is number || !('withdrawableBalance' in data)) &&
             (data.role in ['user', 'admin'] || !('role' in data));
    }

    function isValidTransaction(data) {
      return data.userId is string && 
             (data.amount is number || !('amount' in data)) &&
             (data.type in ['recharge', 'withdraw', 'bonus', 'income', 'referral', 'investment'] || !('type' in data)) &&
             (data.status in ['pending', 'approved', 'rejected', 'completed'] || !('status' in data));
    }

    function isValidInvestment(data) {
      return data.userId is string && data.planId is string &&
             data.status in ['active', 'expired'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if true;
      allow create: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin());
    }

    match /plans/{planId} {
      allow read: if true; // Plans are public
      allow write: if isAdmin();
    }

    match /investments/{investmentId} {
      allow read: if isAuthenticated() && (
        (resource != null && resource.data.userId == request.auth.uid) || 
        isAdmin()
      );
      allow create: if isAuthenticated() && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && (
        (resource != null && resource.data.userId == request.auth.uid) || 
        isAdmin()
      );
      allow create: if isAuthenticated() && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAdmin();
    }

    match /system/settings {
      allow read: if true; // Publicly readable for recharge/team pages
      allow write: if isAdmin();
    }

    match /system/dbConfig {
      allow read, write: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAdmin();
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /coupons/{couponId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
