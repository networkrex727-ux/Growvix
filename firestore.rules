rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Fields: uid, phone, balance, totalIncome, todayIncome, referralCode, referredBy, role, lastCheckIn, createdAt
    //
    // Collection: plans
    // Fields: id, name, price, dailyIncome, validityDays, imageUrl
    //
    // Collection: investments
    // Fields: id, userId, planId, planName, dailyIncome, purchaseDate, expiryDate, lastIncomeClaimed, status
    //
    // Collection: transactions
    // Fields: userId, amount, type, status, paymentMethod, utr, bankDetails, createdAt
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (request.auth.token.email == "mrkhatab112@gmail.com") ||
        (request.auth.token.email == "mohdkhatab@outlook.com") ||
        (request.auth.token.email == "admin@growvix.com") ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isValidUser(data) {
      return data.uid is string && data.phone is string &&
             data.balance is number && data.depositBalance is number &&
             data.withdrawableBalance is number &&
             data.role in ['user', 'admin'];
    }

    function isValidTransaction(data) {
      return data.userId is string && data.amount is number &&
             data.type in ['recharge', 'withdraw', 'bonus', 'income', 'referral', 'investment'] &&
             data.status in ['pending', 'approved', 'rejected', 'completed'];
    }

    function isValidInvestment(data) {
      return data.userId is string && data.planId is string &&
             data.status in ['active', 'expired'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      // Allow read for everyone to support referral checks and password reset email verification
      // Sensitive data should be protected if necessary, but for this app, basic profile is public.
      allow read: if true;
      
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin());
      
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin()) && 
                    isValidUser(request.resource.data) &&
                    request.resource.data.role == resource.data.role && // Prevent self-role escalation
                    request.resource.data.uid == resource.data.uid; // UID is immutable
    }

    match /plans/{planId} {
      allow read: if true; // Plans are public
      allow write: if isAdmin();
    }

    match /investments/{investmentId} {
      // Allow users to read their own investments or admins to read any.
      allow read: if isAuthenticated() && (
        (resource != null && resource.data.userId == request.auth.uid) || 
        isAdmin()
      );
      
      allow create: if isAuthenticated() && 
                    isValidInvestment(request.resource.data) && 
                    (request.resource.data.userId == request.auth.uid || isAdmin());
      
      allow update: if isAuthenticated() && 
                    (resource.data.userId == request.auth.uid || isAdmin()) && 
                    isValidInvestment(request.resource.data) &&
                    request.resource.data.userId == resource.data.userId; // userId is immutable
    }

    match /transactions/{transactionId} {
      // Allow users to read their own transactions or admins to read any.
      allow read: if isAuthenticated() && (
        (resource != null && resource.data.userId == request.auth.uid) || 
        isAdmin()
      );
      
      allow create: if isAuthenticated() && 
                    isValidTransaction(request.resource.data) && 
                    (request.resource.data.userId == request.auth.uid || isAdmin());
      
      allow update: if isAdmin(); // Only admins can approve/reject transactions
    }

    match /system/settings {
      allow read: if true; // Publicly readable for recharge/team pages
      allow write: if isAdmin();
    }
  }
}
